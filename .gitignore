# ===========================================
# Dharmaraj — root .gitignore
# ===========================================

# OS
.DS_Store
Thumbs.db

# Environment & secrets
.env
.env.*
!.env.example
!.env.*.example
frontend/.env.local

# Python
.venv/
venv/
**/.venv/
**/venv/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*

# Node / React
node_modules/
**/node_modules/
frontend/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Logs & runtime
*.log
logs/

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Emergent / local tooling
.emergent/

# Optional: large local asset dumps (keep public/images in frontend)
/Vajra-1_files/
