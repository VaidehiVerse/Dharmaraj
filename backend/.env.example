# Copy to backend/.env and fill in values

# MongoDB — use MONGO_URI (preferred) or MONGO_URL
# URL-encode special characters in the password (@ → %40, # → %23, etc.)
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=dharmaraj_prod

JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@dharmarajayurveda.in
ADMIN_PASSWORD=change-me

FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Razorpay test keys — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_test_secret

# Order notification email (Gmail: use an App Password, not your login password)
# https://myaccount.google.com/apppasswords
ORDER_NOTIFY_EMAIL=dharmarajayurveda@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=your-sender@gmail.com
